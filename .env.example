# === ExodusAI Environment Configuration ===

# Google Cloud Vertex AI (required for backend)
# Auth: run `gcloud auth application-default login` locally,
#        or use attached service account on Cloud Run.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini API key (optional — used by Streamlit demo only)
GOOGLE_API_KEY=your-gemini-api-key-here

# Gemini Live API model (text mode)
GEMINI_MODEL=gemini-2.0-flash-live-001

# Server
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
